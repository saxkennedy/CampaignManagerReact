{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [ "/api/*", "/*.css", "/*.js", "/*.png", "/*.jpg", "/*.svg", "/*.ico" ]
  },
  "routes": [
    {
      "route": "/api/login",
      "allowedRoles": [ "anonymous" ],
      "methods": [ "POST" ]
    },
    {
      "route": "/api/createUser",
      "allowedRoles": [ "anonymous" ],
      "methods": [ "POST" ]
    },
    {
      "route": "/api/*",
      "allowedRoles": [ "anonymous" ]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "X-XSS-Protection": "1; mode=block"
  }
}
